# Copy to .env and fill in. Everything here is optional except where noted.

# --- Location (used for comps search) ---
HOME_ZIP=37377
SEARCH_RADIUS_MILES=100

# --- Value comps ---
# Auto.dev — 1,000 free calls/mo, NO credit card. Sign up: https://auto.dev/signin
# Create a key, paste it here. This is the preferred (free, no-CC) comps source.
AUTODEV_API_KEY=
# Optional alt: MarketCheck (500/mo). Only used if Auto.dev returns nothing.
MARKETCHECK_API_KEY=

# --- Optional LLM layer (listing parsing + candidate ranking) ---
# Uses AWS Bedrock. Leave blank / run with --no-llm to disable.
AWS_REGION=us-east-1
# Verified working in us-east-1: deepseek.v3.2 (cheap, default). Claude fallback:
# us.anthropic.claude-haiku-4-5-20251001-v1:0  (Claude needs the us. inference-profile prefix)
BEDROCK_MODEL_ID=deepseek.v3.2
