# Copy to .env and fill in. Secrets only — location/radius/model live in
# config.toml (copy config.example.toml -> config.toml).

# --- Value comps ---
# Auto.dev — 1,000 free calls/mo, NO credit card. Sign up: https://auto.dev/signin
# Create a key, paste it here. This is the preferred (free, no-CC) comps source.
AUTODEV_API_KEY=
# Optional alt: MarketCheck (500/mo). Only used if Auto.dev returns nothing.
MARKETCHECK_API_KEY=

# --- Web-grounded research (specs/0-60/problems/inspection) ---
# Free by default via DuckDuckGo (no key). Optional: a Serper key (serper.dev,
# free tier, no card) gives higher-quality Google results.
SERPER_API_KEY=

# --- Optional LLM layer (listing parsing + candidate ranking) ---
# Uses AWS Bedrock. Leave blank / run with --no-llm to disable.
AWS_REGION=us-east-1
# Default is Claude Haiku 4.5 (cheap + capable). Claude needs the us. inference
# prefix on Bedrock. Alternatives: a Sonnet/Opus id, or deepseek.v3.2.
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
